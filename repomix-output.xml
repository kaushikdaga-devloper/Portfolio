<file path="src/styles/projects.css">
/* ========== Projects Index Page ========== */
.projects-page { min-height: 100vh; background: var(--color-bg); padding-top: 80px; }
.projects-header h1 {
  background: var(--color-accent-gradient); -webkit-background-clip: text;
  -webkit-text-fill-color: transparent; background-clip: text; font-family: var(--font-display);
}
.projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.8rem; }
.project-tile {
  display: block; text-decoration: none; color: inherit;
  background: rgba(255,255,255,0.03); backdrop-filter: blur(10px);
  border: 1px solid rgba(255,255,255,0.06); border-radius: 24px; overflow: hidden;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  height: 100%; display: flex; flex-direction: column;
}
.project-tile:hover { transform: translateY(-6px); border-color: var(--color-accent); box-shadow: 0 20px 50px rgba(0,0,0,0.6), 0 0 30px rgba(108,92,231,0.2); }
.tile-image { position: relative; height: 220px; background: var(--color-surface); }
.tile-placeholder { position: absolute; inset: 0; background: linear-gradient(135deg, #2d1b4e, #1a0b2e); }
.tile-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 60%); z-index: 1; }
.tile-content {
  position: absolute; bottom: 0; left: 0; right: 0; padding: 1.5rem; z-index: 2;
  color: var(--tile-text-color, #fff); text-shadow: var(--tile-text-shadow, 0 2px 10px rgba(0,0,0,0.5));
}
:root { --tile-text-color: #fff; --tile-text-shadow: 0 2px 10px rgba(0,0,0,0.5); }
body.theme-light { --tile-text-color: #1a1a2e; --tile-text-shadow: none; }
.tile-title { font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; margin-bottom: 0.25rem; }
.tile-desc { font-size: 0.9rem; opacity: 0.85; margin-bottom: 0.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.tile-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.tile-tag { background: rgba(255,255,255,0.15); backdrop-filter: blur(4px); padding: 0.2rem 0.6rem; border-radius: 20px; font-size: 0.7rem; font-weight: 500; color: #fff; }
.tile-footer { display: flex; justify-content: space-between; align-items: center; padding: 1rem 1.5rem; background: rgba(255,255,255,0.03); border-top: 1px solid rgba(255,255,255,0.06); }
.tile-status { font-size: 0.8rem; color: var(--color-accent-light); font-weight: 500; }
.tile-arrow { opacity: 0; transform: translateX(-4px); transition: all 0.3s; }
.project-tile:hover .tile-arrow { opacity: 1; transform: translateX(0); color: var(--color-accent); }

/* ========== Project Detail Page ========== */
.project-detail-new { background: var(--color-bg); min-height: 100vh; padding-top: 80px; }
.detail-hero { position: relative; min-height: 55vh; display: flex; align-items: flex-end; overflow: hidden; }
.hero-bg { position: absolute; inset: 0; }
.hero-img { width: 100%; height: 100%; object-fit: cover; filter: brightness(0.5); }
.hero-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #2d1b4e, #0b0b0f); }
.hero-gradient { position: absolute; inset: 0; background: linear-gradient(to top, var(--color-bg) 0%, transparent 100%); }
.hero-content { position: relative; z-index: 2; padding-bottom: 3rem; color: var(--hero-text-color, #fff); }
:root { --hero-text-color: #fff; --hero-back-link-color: rgba(255,255,255,0.7); }
body.theme-light { --hero-text-color: #1a1a2e; --hero-back-link-color: rgba(0,0,0,0.6); }
.back-link { color: var(--hero-back-link-color); text-decoration: none; font-weight: 500; transition: color 0.2s; }
.back-link:hover { color: var(--hero-text-color); }
.hero-title { font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, 4rem); font-weight: 700; line-height: 1.1; margin-bottom: 1rem; }
.hero-summary { font-size: 1.15rem; max-width: 600px; opacity: 0.9; }
.hero-title-row { display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 2rem; }
.hero-links-desktop { display: flex; gap: 0.8rem; align-items: center; }
.hero-btn {
