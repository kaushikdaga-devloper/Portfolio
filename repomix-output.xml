<file path="src/styles/home.css">
/* ========== Intro Section ========== */
.intro-section { background: radial-gradient(circle at 20% 30%, rgba(108,92,231,0.15) 0%, transparent 50%); }
.floating-shapes { position: absolute; inset: 0; pointer-events: none; }
.shape { position: absolute; border-radius: 50%; background: var(--color-accent-gradient); opacity: 0.2; filter: blur(30px); }
.shape-1 { width: 300px; height: 300px; top: 10%; left: -5%; }
.shape-2 { width: 400px; height: 400px; bottom: 10%; right: -10%; }
.shape-3 { width: 200px; height: 200px; top: 60%; left: 60%; }

.profile-3d-wrapper { position: relative; width: 260px; height: 260px; margin: 0 auto; }
.profile-ring {
  position: absolute; inset: -10px; border-radius: 50%;
  background: var(--color-accent-gradient); opacity: 0.2; filter: blur(20px);
  animation: pulse 3s ease-in-out infinite;
}
.profile-img-hero {
  width: 100%; height: 100%; object-fit: cover; border-radius: 50%;
  position: relative; z-index: 2; border: 4px solid rgba(255,255,255,0.1);
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
}
@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.2; }
  50% { transform: scale(1.1); opacity: 0.4; }
}
.cursor { font-weight: 300; animation: blink 1s infinite; }
@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

/* ---------- Intro text responsiveness ---------- */
@media (max-width: 768px) {
  .intro-section .display-3 {
    font-size: 2.2rem !important;
  }
  .role-wrapper {
    font-size: 1.2rem !important;
  }
}

/* ---------- CTA buttons always side‑by‑side ---------- */
.intro-section .d-flex.flex-wrap.gap-3 {
  flex-wrap: nowrap !important;
}
@media (max-width: 576px) {
  .intro-section .btn {
    padding: 0.6rem 1.2rem;
    font-size: 0.9rem;
  }
}

/* ========== Skills Section ========== */
.filter-pill {
  background: var(--color-surface-card); border: 1px solid var(--color-border);
  color: var(--color-text-secondary); padding: 0.5rem 1.2rem; border-radius: 50px;
  font-weight: 500; font-size: 0.9rem; cursor: pointer; transition: all 0.3s var(--transition-smooth);
}
.filter-pill.active,
.filter-pill:hover { background: var(--color-accent-gradient); color: #fff; border-color: transparent; box-shadow: 0 4px 15px rgba(108,92,231,0.4); }
.skill-card-premium {
  border: 1px solid var(--color-border); background: var(--color-surface);
  backdrop-filter: blur(12px); border-radius: 20px; height: 100%;
  transition: box-shadow 0.3s, border-color 0.3s;
}
.skill-card-premium:hover { border-color: var(--color-accent); box-shadow: var(--shadow-glow), var(--shadow-md); }
.skill-group-title {
  font-family: var(--font-display); font-weight: 600; margin-bottom: 1.5rem;
  font-size: 1.1rem; color: var(--color-text-primary); opacity: 0.9;
}
.skill-item { margin-bottom: 1.2rem; }
.skill-info { display: flex; justify-content: space-between; margin-bottom: 0.3rem; font-size: 0.85rem; font-weight: 500; }
.skill-name { color: var(--color-text-primary); }
.skill-percent { color: var(--color-accent-light); font-weight: 600; }
.skill-track { height: 6px; background: rgba(255,255,255,0.1); border-radius: 10px; position: relative; overflow: visible; }
.skill-fill { height: 100%; background: var(--color-accent-gradient); border-radius: 10px; width: 0; }
.skill-glow {
  position: absolute; top: -4px; width: 12px; height: 12px; background: var(--color-accent-light);
  border-radius: 50%; filter: blur(6px); transform: translateX(-50%); opacity: 0.8;
  box-shadow: 0 0 12px var(--color-accent);
}

/* ========== Domains Section (if used) ========== */
.domains-grid { display: flex; flex-wrap: wrap; gap: 1rem; justify-content: center; }
.domain-link {
  display: flex; flex-direction: column; padding: 1.5rem 2rem;
  background: var(--color-surface-card); backdrop-filter: blur(10px);
  border: 1px solid var(--color-border); border-radius: 20px;
  text-decoration: none; color: var(--color-text-primary);
  transition: all 0.3s var(--transition-smooth); position: relative;
  overflow: hidden; min-width: 220px; flex: 1 1 280px; max-width: 350px;
}
.domain-link::after { content: ''; position: absolute; inset: 0; background: var(--color-accent-gradient); opacity: 0; transition: opacity 0.3s; z-index: 0; }
.domain-link:hover::after { opacity: 0.05; }
.domain-link:hover { transform: translateY(-4px); border-color: var(--color-accent); box-shadow: var(--shadow-md), var(--shadow-glow); }
.domain-link-title { font-family: var(--font-display); font-weight: 600; font-size: 1.25rem; margin-bottom: 0.25rem; position: relative; z-index: 1; }
.domain-link-desc { font-size: 0.9rem; color: var(--color-text-secondary); margin-bottom: 0.75rem; position: relative; z-index: 1; }
.domain-link-arrow {
  align-self: flex-end; opacity: 0.6; transition: transform 0.3s, opacity 0.3s;
  position: relative; z-index: 1; color: var(--color-accent);
}
.domain-link:hover .domain-link-arrow { transform: translateX(6px); opacity: 1; }

/* ========== Education Section ========== */
.education-section { position: relative; }
.edu-timeline-container { max-width: 800px; margin: 0 auto; }
.edu-card-wrapper { position: relative; margin-bottom: 2rem; }
.edu-card {
  display: flex; border-radius: 20px; background: rgba(255,255,255,0.04);
  backdrop-filter: blur(16px); border: 1px solid rgba(255,255,255,0.06);
  padding: 1.5rem; gap: 1.5rem; transition: box-shadow 0.3s, border-color 0.3s;
}
.edu-card:hover { border-color: var(--color-accent); box-shadow: 0 0 30px rgba(108,92,231,0.15); }
.edu-timeline { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.edu-dot { width: 14px; height: 14px; border-radius: 50%; box-shadow: 0 0 12px currentColor; flex-shrink: 0; }
.edu-line { width: 2px; flex: 1; min-height: 40px; opacity: 0.4; }
.edu-content { flex: 1; }
.edu-degree { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; margin-bottom: 0.2rem; color: var(--color-text-primary); }
.edu-status-badge { padding: 0.3rem 0.9rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; white-space: nowrap; }
.edu-institution { font-size: 1rem; font-weight: 500; color: var(--color-accent-light); margin-bottom: 0.15rem; }
.edu-location { font-size: 0.85rem; color: var(--color-text-secondary); margin-bottom: 1rem; }
.edu-meta-row { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 1rem; }
.edu-meta-item {
  display: flex; align-items: center; gap: 0.4rem; font-size: 0.85rem;
  color: var(--color-text-secondary); background: rgba(255,255,255,0.04);
  padding: 0.4rem 0.8rem; border-radius: 8px;
}
.edu-meta-item svg { flex-shrink: 0; opacity: 0.6; }
.edu-highlights { list-style: none; padding: 0; margin: 0; }
.edu-highlights li {
  position: relative; padding-left: 1.2rem; margin-bottom: 0.4rem;
  font-size: 0.85rem; color: var(--color-text-secondary); line-height: 1.5;
}
.edu-highlights li::before {
  content: ''; position: absolute; left: 0; top: 0.55rem;
  width: 6px; height: 6px; border-radius: 50%; background: var(--color-accent);
}
@media (max-width: 576px) {
  .edu-card { flex-direction: column; gap: 0.5rem; }
  .edu-timeline { flex-direction: row; align-items: center; }
  .edu-line { width: 40px; height: 2px; min-height: auto; }
}

/* ========== Currently Learning ========== */
.learning-card {
  border-radius: 16px; cursor: default; transition: all 0.3s ease;
  background: var(--color-surface-card); border: 1px solid var(--color-border);
}
.learning-card:hover { border-color: var(--color-accent); box-shadow: 0 4px 15px rgba(108,92,231,0.2); }
.learning-icon { font-size: 1.2rem; }
.learning-name { font-weight: 500; color: var(--color-text-primary); }

/* ========== Featured Projects (Home) ========== */
.project-card-featured { transition: transform 0.3s, box-shadow 0.3s; color: inherit; }
.project-card-featured:hover { transform: translateY(-5px); }
</file>

<file path="src/styles/layout.css">
/* ========== Header ========== */
.site-header {
  transition: background 0.4s ease, backdrop-filter 0.4s, box-shadow 0.4s;
  background: transparent;
  backdrop-filter: blur(0px);
  padding: 1rem 0;
  z-index: 1000;
}
.header-scrolled {
  background: var(--header-scrolled-bg, rgba(11,11,15,0.75));
  backdrop-filter: blur(20px);
  box-shadow: 0 4px 30px rgba(0,0,0,0.1);
}
:root { --header-scrolled-bg: rgba(11,11,15,0.75); }
body.theme-light { --header-scrolled-bg: rgba(250,250,250,0.85); }

.brand {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 700;
  color: var(--color-text-primary);
  text-decoration: none;
  letter-spacing: -1px;
}
.accent-dot { color: var(--color-accent); }
.nav-link {
  font-weight: 500;
  color: var(--color-text-secondary) !important;
  position: relative;
  padding: 0.5rem 1rem;
  transition: color 0.2s;
}
.nav-link:hover,
.nav-link.active { color: var(--color-text-primary) !important; }
.nav-link::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%) scaleX(0);
  width: 60%;
  height: 2px;
  background: var(--color-accent);
  transition: transform 0.3s ease;
}
.nav-link:hover::after,
.nav-link.active::after { transform: translateX(-50%) scaleX(1); }

.custom-toggler {
  border: none;
  background: transparent;
  width: 30px;
  height: 20px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  cursor: pointer;
}
.toggler-bar {
  width: 100%;
  height: 2px;
  background: var(--color-text-primary);
  transition: transform 0.3s ease, opacity 0.3s;
}
.custom-toggler.open .toggler-bar:nth-child(1) { transform: translateY(8px) rotate(45deg); }
.custom-toggler.open .toggler-bar:nth-child(2) { opacity: 0; }
.custom-toggler.open .toggler-bar:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }
@media (max-width: 991.98px) {
  .navbar-collapse {
    background: var(--color-bg);
    border-radius: 12px;
    margin-top: 1rem;
    padding: 1rem;
    box-shadow: var(--shadow-md);
  }
}
.theme-toggle-btn { background: none; border: none; font-size: 1.2rem; cursor: pointer; }

/* Nav icons & dropdown */
.nav-link { display: flex; align-items: center; gap: 0.4rem; }
.nav-icon { display: flex; align-items: center; opacity: 0.7; transition: opacity 0.2s; }
.nav-link:hover .nav-icon,
.nav-link.active .nav-icon { opacity: 1; color: var(--color-accent); }
.more-trigger {
  cursor: pointer; background: none; border: none;
  font-weight: 500; display: flex; align-items: center; gap: 0.3rem;
}
.more-dropdown {
  position: absolute; top: calc(100% + 10px); right: 0;
  background: rgba(20, 20, 30, 0.95); backdrop-filter: blur(20px);
  border: 1px solid var(--color-border); border-radius: 16px;
  padding: 1rem; min-width: 260px; z-index: 1001;
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
}
.more-dropdown-grid { display: flex; flex-direction: column; gap: 0.3rem; }
.more-dropdown-item {
  display: flex; align-items: center; gap: 0.6rem; padding: 0.7rem 1rem;
  border-radius: 10px; color: var(--color-text-secondary); text-decoration: none;
  font-weight: 500; transition: all 0.2s ease;
}
.more-dropdown-item:hover { background: rgba(108, 92, 231, 0.12); color: var(--color-text-primary); }
.more-dd-icon { display: flex; align-items: center; opacity: 0.8; }
.more-dropdown-item:hover .more-dd-icon { opacity: 1; color: var(--color-accent); }
@media (max-width: 991.98px) {
  .more-dropdown { position: static; box-shadow: none; background: transparent; backdrop-filter: none; border: none; padding: 0; margin-top: 0.5rem; }
  .more-dropdown-grid { flex-direction: column; }
}

/* ---------- Mobile header adjustments ---------- */
@media (max-width: 575.98px) {
  .brand {
    font-size: 1.4rem;
  }
  .navbar {
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
  }
}

/* ========== Footer ========== */
.site-footer {
  margin-top: 4rem;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  background: rgba(255, 255, 255, 0.02);
  backdrop-filter: blur(12px);
}
.footer-top { padding: 3rem 0 2rem; }
.footer-brand-link {
