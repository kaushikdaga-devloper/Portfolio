.footer-links li,
.footer-contact li { margin-bottom: 0.5rem; }
.footer-link { color: var(--color-text-secondary); text-decoration: none; font-size: 0.9rem; font-weight: 500; transition: color 0.2s, transform 0.2s; display: inline-block; }
.footer-link:hover { color: var(--color-accent); transform: translateX(3px); }
.footer-cta-text { line-height: 1.6; margin-bottom: 0.8rem; }
