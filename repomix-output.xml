  font-family: var(--font-display); font-size: 1.6rem;
  font-weight: 700; letter-spacing: -1px; margin-bottom: 0.5rem;
}
.footer-brand-link:hover { color: var(--color-text-primary); }
.footer-tagline { font-size: 0.9rem; color: var(--color-text-secondary); margin-bottom: 0; }
.footer-socials { display: flex; gap: 0.6rem; align-items: center; }
.footer-social-icon {
