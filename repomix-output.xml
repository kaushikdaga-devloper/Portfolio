<file path="src/styles/assistant.css">
/* ========== Assistant Widget ========== */
.assistant-fab {
  position: fixed; bottom: 2rem; right: 2rem; width: 56px; height: 56px;
  border-radius: 50%; background: var(--color-accent-gradient); border: none;
  color: #fff; display: flex; align-items: center; justify-content: center;
  cursor: pointer; z-index: 1050; box-shadow: 0 8px 30px rgba(108,92,231,0.4);
  transition: box-shadow 0.3s;
}
.assistant-fab:hover { box-shadow: 0 12px 40px rgba(108,92,231,0.6); }
.assistant-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 1060; display: flex; align-items: flex-end; justify-content: flex-end; padding: 2rem; }
.assistant-panel {
  width: 400px; max-width: 100%; height: 550px; max-height: 80vh;
  background: var(--assistant-panel-bg, rgba(20,20,30,0.9));
  border: 1px solid var(--color-border);
  border-radius: 20px; box-shadow: var(--shadow-md), 0 0 40px rgba(108,92,231,0.15);
  display: flex; flex-direction: column; overflow: hidden;
  backdrop-filter: blur(20px);
}
:root { --assistant-panel-bg: rgba(20,20,30,0.9); }
body.theme-light { --assistant-panel-bg: rgba(255,255,255,0.92); }
.assistant-panel-header { display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 1.5rem; border-bottom: 1px solid var(--color-border); background: rgba(255,255,255,0.03); }
.assistant-title { font-family: var(--font-display); font-weight: 600; font-size: 1.1rem; margin-bottom: 0.2rem; color: var(--color-text-primary); }
.assistant-subtitle { font-size: 0.75rem; color: var(--color-text-secondary); }
.assistant-close { background: none; border: none; color: var(--color-text-secondary); cursor: pointer; padding: 4px; border-radius: 6px; transition: color 0.2s, background 0.2s; }
.assistant-close:hover { color: #fff; background: rgba(255,255,255,0.1); }
.assistant-messages { flex: 1; overflow-y: auto; padding: 1.5rem; display: flex; flex-direction: column; gap: 12px; }
.assistant-empty { text-align: center; color: var(--color-text-secondary); padding: 2rem 1rem; }
.assistant-bubble { max-width: 85%; padding: 0.8rem 1rem; border-radius: 16px; font-size: 0.9rem; line-height: 1.4; color: var(--color-text-primary); }
.assistant-bubble.user { align-self: flex-end; background: var(--color-accent-gradient); color: #fff; }
.assistant-bubble.assistant { align-self: flex-start; background: rgba(255,255,255,0.06); border: 1px solid var(--color-border); }
.typing-indicator { display: flex; gap: 4px; padding: 0.4rem 0; }
.typing-indicator span { width: 8px; height: 8px; border-radius: 50%; background: var(--color-text-secondary); animation: bounce 1.2s infinite ease-in-out; }
.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-8px); opacity: 1; } }
.assistant-input-area { display: flex; padding: 1rem; border-top: 1px solid var(--color-border); background: rgba(0,0,0,0.2); }
.assistant-input-area input { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid var(--color-border); border-radius: 12px; padding: 0.7rem 1rem; color: var(--color-text-primary); font-size: 0.9rem; outline: none; transition: border-color 0.2s; }
.assistant-input-area input:focus { border-color: var(--color-accent); }
.assistant-send-btn { margin-left: 0.5rem; background: var(--color-accent-gradient); border: none; border-radius: 12px; padding: 0.7rem; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: opacity 0.2s; }
.assistant-send-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* Action buttons */
.assistant-buttons { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.8rem; }
.assistant-action-btn {
  background: rgba(108, 92, 231, 0.25);
  border: 1px solid rgba(108, 92, 231, 0.4);
  color: var(--color-accent-light);
  padding: 0.5rem 1.1rem;
  border-radius: 50px;
  font-weight: 500; font-size: 0.85rem;
  cursor: pointer; transition: all 0.2s ease;
  display: flex; align-items: center; gap: 0.3rem;
}
.assistant-action-btn:hover { background: var(--color-accent); color: #fff; border-color: transparent; box-shadow: 0 4px 15px rgba(108,92,231,0.3); }

/* Home prompt */
.assistant-home-prompt {
  position: fixed; bottom: 100px; right: 2rem; z-index: 1040;
  display: flex; align-items: center; gap: 0.5rem;
  background: rgba(255, 255, 255, 0.06); backdrop-filter: blur(16px);
  border: 1px solid rgba(255, 255, 255, 0.12); border-radius: 50px;
  padding: 0.6rem 1.3rem; font-size: 0.9rem; font-weight: 500;
  color: var(--color-text-primary); cursor: pointer;
  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
  transition: border-color 0.3s, box-shadow 0.3s;
  animation: subtleGlow 2.5s infinite alternate;
}
@keyframes subtleGlow {
  0% { box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3), 0 0 10px rgba(108, 92, 231, 0.1); }
  100% { box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3), 0 0 18px rgba(108, 92, 231, 0.25); }
}
.assistant-home-prompt:hover { border-color: var(--color-accent); box-shadow: 0 12px 30px rgba(0, 0, 0, 0.4), 0 0 25px rgba(108, 92, 231, 0.35); }

/* Suggestions */
.assistant-suggestions { list-style: none; padding: 0; margin-top: 0.8rem; text-align: left; }
.assistant-suggestions li { padding: 0.3rem 0; font-size: 0.9rem; color: var(--color-text-secondary); }

@media (max-width: 576px) {
  .assistant-fab { right: 1rem; bottom: 1rem; }
  .assistant-overlay { padding: 1rem; }
  .assistant-panel { width: 100%; height: 70vh; }

  .assistant-home-prompt {
    right: 0.5rem;
    bottom: 85px;
    font-size: 0.72rem;
    padding: 0.4rem 0.8rem;
    max-width: calc(100vw - 60px);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
}
