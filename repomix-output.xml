.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 30px rgba(108, 92, 231, 0.5);
  background: var(--color-accent-gradient);
}

.btn-outline-primary {
  border: 2px solid var(--color-accent);
  color: var(--color-accent);
  background: transparent;
  font-weight: 600;
  padding: 0.7rem 1.8rem;
  border-radius: 50px;
  transition: all 0.3s var(--transition-smooth);
}
.btn-outline-primary:hover {
  background: var(--color-accent);
  color: #fff;
  box-shadow: 0 4px 20px rgba(108, 92, 231, 0.3);
}

/* Glass card */
.glass-card {
  background: var(--color-surface-card);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  transition: all 0.4s var(--transition-smooth);
}
.glass-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md), var(--shadow-glow);
  border-color: var(--color-accent);
}

/* Scrollbar */
::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: var(--color-bg); }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.3); }
* { scrollbar-width: thin; scrollbar-color: rgba(255,255,255,0.15) var(--color-bg); }

/* Bootstrap overrides */
.text-muted { color: var(--color-text-secondary) !important; }
.bg-light { background-color: var(--color-surface) !important; }
body .bg-light { background-color: var(--color-surface) !important; }

/* Loader */
.projects-loader { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 50vh; }
.spinner {
  width: 48px; height: 48px; border: 4px solid rgba(255,255,255,0.1);
  border-top-color: var(--color-accent); border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
</file>

