    viewport={{ once: true, margin: '-50px' }}
    transition={{ duration: 0.6, delay }}
  >
    {children}
  </motion.div>
);

const Lightbox = ({ src, alt, onClose }) => (
  <motion.div
    className="lightbox-overlay"
    initial={{ opacity: 0 }}
    animate={{ opacity: 1 }}
    exit={{ opacity: 0 }}
    onClick={onClose}
  >
    <motion.img
      src={src}
      alt={alt}
      className="lightbox-image"
